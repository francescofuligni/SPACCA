                        <Text fill="WHITE" layoutX="228.0" layoutY="235.0" strokeType="OUTSIDE" strokeWidth="0.0" text="Le modalità di gioco sono 2: Partita Singola e Torneo. Il Torneo è disponibile in due ulteriori versioni: Semplice e Last Man Standing." wrappingWidth="763.9970703125">
                           <font>
                              <Font name="Times New Roman" size="22.0" />
                           </font>
